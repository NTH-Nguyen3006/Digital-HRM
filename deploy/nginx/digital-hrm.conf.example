map $http_upgrade $connection_upgrade {
    default upgrade;
    '' close;
}

map $http_cf_connecting_ip $client_real_ip {
    default $http_cf_connecting_ip;
    '' $remote_addr;
}

server {
    listen 80;
    server_name hrm.example.com;

    client_max_body_size 20m;

    # Cloudflare SSL terminates at the edge, then forwards to origin over HTTP.
    # Redirect only when the original client request was not HTTPS to avoid loops.
    if ($http_x_forwarded_proto != "https") {
        return 301 https://$host$request_uri;
    }

    location / {
        proxy_pass http://127.0.0.1:8088;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $client_real_ip;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $http_x_forwarded_proto;
        proxy_set_header CF-Connecting-IP $client_real_ip;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 300s;
    }
}
