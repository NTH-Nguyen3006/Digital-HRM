COMPOSE_PROJECT_NAME=digital-hrm

BACKEND_IMAGE=ghcr.io/your-org-or-user/digital-hrm-backend:latest
FRONTEND_IMAGE=ghcr.io/your-org-or-user/digital-hrm-frontend:latest

TZ=Asia/Ho_Chi_Minh

MSSQL_DATABASE=DigitalHRM
MSSQL_SA_PASSWORD=ChangeThisStrongPassword123!

FRONTEND_BIND_ADDRESS=127.0.0.1
FRONTEND_BIND_PORT=8088

APP_CORS_ALLOWED_ORIGINS=https://hrm.example.com
APP_COOKIE_DOMAIN=hrm.example.com
APP_JWT_SECRET=replace-this-with-a-long-random-secret

APP_BOOTSTRAP_SEED_DEFAULT_ADMIN=true
APP_BOOTSTRAP_ADMIN_USERNAME=admin
APP_BOOTSTRAP_ADMIN_EMAIL=admin@hrm.example.com
APP_BOOTSTRAP_ADMIN_PASSWORD=ChangeThisAdminPassword123!
APP_BOOTSTRAP_ADMIN_PHONE_NUMBER=0900000000

APP_MAIL_MOCK_ENABLED=true
APP_MAIL_FROM_ADDRESS=no-reply@hrm.example.com
APP_MAIL_RESET_URL_BASE=https://hrm.example.com/auth/reset-password

APP_STORAGE_MAX_FILE_SIZE_MB=20
APP_REPORTING_SCHEDULER_ENABLED=true
APP_REPORTING_SCHEDULER_FIXED_DELAY_MS=300000
